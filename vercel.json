{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node@3.0.0" },
    { "src": "index.html", "use": "@vercel/static@2.0.0" },
    { "src": "*.png", "use": "@vercel/static@2.0.0" },
    { "src": "*.webp", "use": "@vercel/static@2.0.0" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
